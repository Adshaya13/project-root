# =========================================================
# CampusFlow Backend Environment Template
# Copy this file to .env and replace placeholder values.
# =========================================================

# ----------------------------
# Server
# ----------------------------
SERVER_PORT=8081
APP_NAME=SmartCampus

# ----------------------------
# Database (MongoDB)
# ----------------------------
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/smart_campus_hub
SPRING_DATA_MONGODB_DATABASE=smart_campus_hub
# ----------------------------
# JWT Auth
# ----------------------------
# Use a long random secret (at least 32 characters)
JWT_SECRET=change-this-secret-to-a-long-random-value-at-least-32-chars
JWT_EXPIRATION_MINUTES=120

# ----------------------------
# SMTP Email (OTP + Password Reset)
# ----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=arunnallavan73@gmail.com
SMTP_PASSWORD=jubkctzcedngsmko
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_STARTTLS_REQUIRED=true

# ----------------------------
# Google Auth
# ----------------------------
GOOGLE_CLIENT_ID=788718724251-uik60ojg01cbcss9eg4njvlokoriduft.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google
FRONTEND_URL=http://localhost:5173
OAUTH2_REDIRECT_URI=http://localhost:5173/auth/google
# ----------------------------
