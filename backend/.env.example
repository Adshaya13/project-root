# =========================================================
# CampusFlow Backend Environment Template
# Copy this file to .env and update values accordingly
# =========================================================

# ----------------------------
# Server
# ----------------------------
SERVER_PORT=8081
APP_NAME=Campus-Hub

# ----------------------------
# Database (MongoDB)
# ----------------------------
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/campus_flow
SPRING_DATA_MONGODB_DATABASE=campus_flow

# ----------------------------
# JWT Auth
# ----------------------------
JWT_SECRET=your-very-long-random-secret-key-min-32-characters
JWT_EXPIRATION_MINUTES=120

# ----------------------------
# SMTP Email (OTP + Password Reset)
# ----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_STARTTLS_REQUIRED=true

# ----------------------------
# Google Auth
# ----------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_CALLBACK_URI=http://localhost:8081/login/oauth2/code/google
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google
FRONTEND_URL=http://localhost:5173
OAUTH2_REDIRECT_URI=http://localhost:5173/auth/google

# ----------------------------
# Bootstrap Admin User
# ----------------------------
BOOTSTRAP_ADMIN_NAME=System Admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin-password

# ----------------------------
# Bootstrap Test Student User
# ----------------------------
BOOTSTRAP_STUDENT_NAME=Test Student
BOOTSTRAP_STUDENT_EMAIL=student@example.com
BOOTSTRAP_STUDENT_PHONE=+94000000000
BOOTSTRAP_STUDENT_PASSWORD=student-password

# ----------------------------
# Bootstrap Test Staff User
# ----------------------------
BOOTSTRAP_STAFF_NAME=Test Staff
BOOTSTRAP_STAFF_EMAIL=staff@example.com
BOOTSTRAP_STAFF_PHONE=+94000000000
BOOTSTRAP_STAFF_PASSWORD=staff-password

# ----------------------------
# CORS (comma-separated origins)
# ----------------------------
APP_CORS_ORIGINS=http://localhost:8081,http://localhost:5173,http://localhost:3000