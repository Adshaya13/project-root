# =========================================================
# CampusFlow Backend Environment Template
# Copy this file to .env and replace placeholder values.
# =========================================================

# ----------------------------
# Server
# ----------------------------
SERVER_PORT=8081
APP_NAME=CampusFlow

# ----------------------------
# Database (MySQL)
# ----------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=backend
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# ----------------------------
# JWT Auth
# ----------------------------
# Use a long random secret (at least 32 characters)
JWT_SECRET=change-this-secret-to-a-long-random-value-at-least-32-chars
JWT_EXPIRATION_MINUTES=120

# ----------------------------
# SMTP Email (OTP + Password Reset)
# ----------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_STARTTLS_REQUIRED=true

# ----------------------------
# Google Auth
# ----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ----------------------------
# Bootstrap Admin User
# ----------------------------
BOOTSTRAP_ADMIN_NAME=System Admin
BOOTSTRAP_ADMIN_EMAIL=admin@campusflow.local
BOOTSTRAP_ADMIN_PASSWORD=Admin@1234

# ----------------------------
# CORS (comma-separated origins)
# ----------------------------
APP_CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000
